+// Shared helper for resolving <home>/Desktop/<name>, used by both the
+// blind-spot log and the learned-mistakes store so they stay consistent
+// across platforms (Windows: USERPROFILE, Linux/macOS: HOME).
+std::string desktop_path(const char* filename) {
+#ifdef _WIN32
+    const char* home = std::getenv("USERPROFILE");
+#else
+    const char* home = std::getenv("HOME");
+#endif
+    return (home ? std::string(home) : std::string(".")) + "/Desktop/" + filename;
+}
+
+// Appends one line to a curated "blind spot" log on the user's Desktop --
+// NOT the whole game, only moments where the root's best score regressed
+// sharply between two consecutive completed depths. That pattern means a
+// shallower search (the kind a 2s time budget can be cut off at) would have
+// reported a move this engine now knows is worse than it first looked, i.e.
+// an evaluation blind spot. Intended for manual review/hand-tuning since
+// retraining the NNUE net is out of scope for this project.
+//
+// Called from the main thread only (see call site in iterative_deepening),
+// so the lazily-initialized static ofstream needs no locking. Any failure to
+// open/write the file is swallowed silently -- logging must never be able
+// to affect the search itself.
+void log_blind_spot(const Position& rootPos, Depth depth, Value oldScore, Value newScore, Move bestMove) {
+
+    static std::ofstream logFile(desktop_path("pikafish_blindspots.log"), std::ios::app);
+
+    if (!logFile.is_open())
+        return;
+
+    const int prevCp = UCIEngine::to_cp(oldScore, rootPos);
+    const int newCp  = UCIEngine::to_cp(newScore, rootPos);
+
+    logFile << "depth=" << depth << " move=" << UCIEngine::move(bestMove) << " prev_cp=" << prevCp
+            << " new_cp=" << newCp << " drop_cp=" << (prevCp - newCp) << " fen=" << rootPos.fen()
+            << '\n';
+    logFile.flush();
+}
+
+// Persistent "learned mistakes" table: Zobrist key -> moves previously
+// refuted from that EXACT position (a shallower iteration thought the move
+// was good, a deeper one proved it wasn't -- see log_blind_spot's caller).
+// Loaded once from disk (Desktop/pikafish_learned.log) via a magic-static,
+// so initialization is thread-safe; all subsequent reads/writes are done
+// from the main thread ONLY (see call sites), so no locking is needed.
+std::unordered_map<Key, std::vector<Move>>& learned_bad_moves() {
+    static std::unordered_map<Key, std::vector<Move>> table = [] {
+        std::unordered_map<Key, std::vector<Move>> t;
+        std::ifstream                              in(desktop_path("pikafish_learned.log"));
+        std::string                                line;
+        while (std::getline(in, line))
+        {
+            std::istringstream iss(line);
+            std::string        keyTok, moveTok;
+            if (iss >> keyTok >> moveTok)
+                t[Key(std::strtoull(keyTok.c_str(), nullptr, 16))].push_back(
+                  Move(std::uint16_t(std::strtoul(moveTok.c_str(), nullptr, 16))));
+        }
+        return t;
+    }();
+    return table;
+}
+
+bool is_learned_bad(Key key, Move m) {
+    auto it = learned_bad_moves().find(key);
+    return it != learned_bad_moves().end()
+        && std::find(it->second.begin(), it->second.end(), m) != it->second.end();
+}
+
+// Records (key, move) as a known regression. Deduped in memory first, so a
+// repeat of the same lesson never grows the file -- matches the requirement
+// to log only NEW mistakes, not every time the same one recurs.
+void remember_bad_move(Key key, Move m) {
+    auto& vec = learned_bad_moves()[key];
+    if (std::find(vec.begin(), vec.end(), m) != vec.end())
+        return;
+    vec.push_back(m);
+
+    std::ofstream out(desktop_path("pikafish_learned.log"), std::ios::app);
+    if (out.is_open())
+        out << std::hex << key << ' ' << m.raw() << std::dec << '\n';
+}
