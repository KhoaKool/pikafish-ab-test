+void Engine::load_own_book(const std::string& path) {
+    ownBook.clear();
+
+    std::ifstream in(path);
+    if (!in.is_open())
+        return;  // no book yet (or bad path) -- OwnBook simply has nothing to offer, not an error
+
+    std::string line;
+    while (std::getline(in, line))
+    {
+        // Lines look like: fen=<FEN> move=<uci> depth=<int> source=<tag>
+        // The FEN itself may contain spaces, so locate each "key=" marker
+        // explicitly rather than splitting on whitespace.
+        auto fenPos  = line.find("fen=");
+        auto movePos = line.find(" move=");
+        if (fenPos == std::string::npos || movePos == std::string::npos || movePos <= fenPos)
+            continue;
+
+        std::string fen        = line.substr(fenPos + 4, movePos - (fenPos + 4));
+        auto        afterMove  = movePos + 6;
+        auto        depthPos   = line.find(" depth=", afterMove);
+        std::string moveStr    = depthPos == std::string::npos ? line.substr(afterMove)
+                                                                 : line.substr(afterMove, depthPos - afterMove);
+
+        Position  tempPos;
+        StateInfo si;
+        if (!tempPos.set(fen, &si).has_value())
+            ownBook[tempPos.key()] = moveStr;
+    }
+}
